# ============================================================
# 本地配置文件模板
# 使用方法: 复制此文件为 config.local.yaml，填入你的配置
#   cp config.local.yaml.example config.local.yaml
# ============================================================

# GitHub Personal Access Token (可选但推荐)
# 创建方法: GitHub Settings → Developer settings → Personal access tokens → Generate new token (classic)
# 权限: 只需勾选 public_repo (读取公开仓库信息)
# 不配置也可运行，但API速率限制为 60次/小时 (配置后为 5000次/小时)
github_token: ""

# HTTP/HTTPS 代理 (可选，需要梯子时填写)
# 例如: "http://127.0.0.1:你的端口"
proxy: ""

# 是否启用代理
use_proxy: false
